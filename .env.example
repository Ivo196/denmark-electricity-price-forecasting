# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Energi Data Service (no key required for public endpoints, but useful for rate limiting)
ENERGIDATA_BASE_URL=https://api.energidataservice.dk/dataset

# Open-Meteo (free tier, no key needed)
OPENMETEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# Optional: KNMI / DMI API key if you switch to a national weather service
DMI_API_KEY=your_dmi_api_key_here

# Model artefact storage
MODEL_DIR=models/
DATA_DIR=data/
